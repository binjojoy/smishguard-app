<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvStatusIconBg"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivStatusIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_check" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvPopupTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/manrope_bold"
                        android:textSize="22sp"
                        android:text="Security Analysis" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="ANALYSIS BREAKDOWN"
                    android:fontFamily="@font/inter_medium"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#64748B"/>

                <TextView
                    android:id="@+id/tvAnalysisWhy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/inter_regular"
                    android:lineSpacingExtra="4dp"
                    android:text="Linguistic patterns indicate high-pressure tactics..."
                    android:textColor="#334155"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_popup_details_border"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AI NLP Confidence" android:fontFamily="@font/inter_medium" android:textSize="12sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvAiScore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true" android:fontFamily="@font/manrope_bold" android:text="0/100"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Forensic Meta-Check" android:fontFamily="@font/inter_medium" android:textSize="12sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvForensicScore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true" android:fontFamily="@font/manrope_bold" android:text="0/100"/>
                    </RelativeLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPopupMessageBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="#F8FAFC"
                    android:padding="12dp"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="13sp"
                    android:fontStyle="italic"
                    android:textColor="#475569" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnFeedbackAction"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_popup_btn_teal"
                    android:fontFamily="@font/manrope_bold"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:text="Report Missed Scam" />

                <TextView
                    android:id="@+id/btnDismiss"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="Dismiss Report"
                    android:fontFamily="@font/manrope_bold"
                    android:textColor="#94A3B8"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>